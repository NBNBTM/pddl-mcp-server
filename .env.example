# PDDL MCP runtime configuration

# Optional. If unset, natural-language parsing uses deterministic local fallback.
LLM_API_URL=
LLM_API_KEY=
# Backward-compatible alias, used only if LLM_API_KEY is empty.
LLM_API_TOKEN=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=30
LLM_RETRIES=1

# Required for real planning. If unset, the server still generates domain/problem PDDL.
# Examples:
# FAST_DOWNWARD_PATH=/absolute/path/to/fast-downward.py
# FAST_DOWNWARD_PATH=python /absolute/path/to/fast-downward.py
# FAST_DOWNWARD_PATH=wsl -d Ubuntu-22.04 python3 /home/user/downward/fast-downward.py
FAST_DOWNWARD_PATH=
FAST_DOWNWARD_SEARCH=astar(blind())
MAX_PLANNING_TIME=300

OUTPUT_DIR=output
LOG_LEVEL=INFO
