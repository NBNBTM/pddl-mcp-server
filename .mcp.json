{
  "title": "PDDL Planner",
  "description": "MCP server for natural-language-to-PDDL modeling and Fast Downward planning.",
  "version": "4.0.0",
  "entrypoint": "server.py",
  "python_version": ">=3.10",
  "dependencies": ["pddl-mcp"],
  "capabilities": ["plan_from_text", "generate_plan", "validate_config", "get_system_info"],
  "mcpServers": {
    "pddl-planner": {
      "command": "python",
      "args": ["server.py"],
      "cwd": "."
    }
  }
}
